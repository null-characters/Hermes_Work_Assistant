# ===========================================
# Hermes Work Assistant 环境变量配置
# ===========================================
# 复制此文件为 .env 并填写实际值
#
# 支持两种使用场景：
# 1. 本地文件处理：只需配置 [LLM] 部分
# 2. 企业微信 + 金蝶 ERP：需额外配置 [金蝶] 和 [企微] 部分
#
# 详细指南：docs/LOCAL_DEV_GUIDE.md

# ===========================================
# [必须] Hermes LLM 配置
# ===========================================
# 方式 1: OpenRouter（推荐，200+ 模型可选）
HERMES_PROVIDER=openrouter
HERMES_MODEL=anthropic/claude-3-sonnet
OPENROUTER_API_KEY=sk-or-xxx

# 方式 2: 自定义 OpenAI 兼容端点
# HERMES_PROVIDER=custom
# HERMES_MODEL=glm-5
# OPENAI_API_KEY=your-api-key
# OPENAI_BASE_URL=https://api.lkeap.cloud.tencent.com/v1

# 方式 3: 其他提供商（详见 Hermes 文档）
# DeepSeek:    DEEPSEEK_API_KEY
# 智谱 GLM:     GLM_API_KEY
# Kimi/月之暗面: KIMI_API_KEY
# Mistral:     MISTRAL_API_KEY
# xAI/Grok:    XAI_API_KEY
# Google/Gemini: GOOGLE_API_KEY

# ===========================================
# [可选] 金蝶 ERP 配置（用于 ERP 集成）
# ===========================================
# 金蝶服务器地址
KINGDEE_API_URL=http://your-kingdee-server/K3Cloud

# 数据中心 ID（账套 ID）
KINGDEE_ACCT_ID=your_acct_id

# 登录用户名
KINGDEE_USERNAME=your_username

# 登录密码
KINGDEE_PASSWORD=your_password

# 语言 ID（2052=简体中文, 1033=英文）
KINGDEE_LCID=2052

# ===========================================
# [可选] 企业微信配置（用于企微 Bot）
# ===========================================
# 企业 ID
WECHAT_CORP_ID=your_corp_id

# 应用 AgentId
WECHAT_AGENT_ID=your_agent_id

# 应用 Secret
WECHAT_SECRET=your_secret

# 回调 Token
WECHAT_TOKEN=your_token

# 回调 EncodingAESKey
WECHAT_ENCODING_AES_KEY=your_aes_key

# ===========================================
# [可选] 会话存储配置
# ===========================================
# 会话目录基础路径（容器内）
SESSION_BASE_PATH=/app/data/sessions

# ===========================================
# Terminal 安全配置
# ===========================================
TERMINAL_BACKEND=local
# 执行超时 (秒)
TERMINAL_TIMEOUT=300
# 网络隔离 (安全关键)
TERMINAL_NETWORK_DISABLED=true
# 只读根文件系统
TERMINAL_READ_ONLY_ROOT=true
# 进程数限制
TERMINAL_MAX_PROCESSES=100
# 容器资源限制
TERMINAL_CONTAINER_CPU=1
TERMINAL_CONTAINER_MEMORY=2048

# ===========================================
# [可选] 其他配置
# ===========================================
# 日志级别
LOG_LEVEL=INFO
# 文件过期天数
FILE_EXPIRE_DAYS=7
# CORS 允许的域名
CORS_ORIGINS=http://localhost:*
# 审计日志目录
AUDIT_LOG_DIR=/app/data/audit